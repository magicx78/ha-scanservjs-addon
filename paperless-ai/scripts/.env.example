# Paperless-AI – Secrets als Umgebungsvariablen
# Kopieren nach .env und mit echten Werten befüllen.
# Diese Datei NIEMALS in Git einchecken (enthält echte Tokens).

# Paperless-ngx
PAPERLESS_URL=http://ca5234a0-paperless-ngx:8000
PAPERLESS_TOKEN=dein-paperless-api-token

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...

# Home Assistant (optional – nur für HA-Benachrichtigungen)
HA_URL=http://homeassistant.local:8123
HA_TOKEN=dein-ha-long-lived-access-token
HA_NOTIFY_TARGET=notify.mobile_app_iphone
