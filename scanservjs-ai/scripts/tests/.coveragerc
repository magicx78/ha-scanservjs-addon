[run]
# Coverage-Konfiguration

source = ..
omit =
    */site-packages/*
    */tests/*
    */test_*.py
    __pycache__/*
    */venv/*

[report]
# Aussagekräftige Coverage-Reports

exclude_lines =
    pragma: no cover
    def __repr__
    def __str__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    if DEBUG:
    if TESTING:

precision = 2
skip_covered = false
skip_empty = true

[html]
directory = htmlcov
